#include <bits/stdc++.h>
using namespace std;
class Counter{
private:
   int id;
   static int totalCounters;

public:
   Counter(){
       totalCounters++;    //использовал конструктор по умолчанию
       id = totalCounters;
       cout << "счетчик #" << id << "создан" << "\n";
   }
   
   
   ~Counter(){       //деструктор
       totalCounters--;
       cout << "счетчик #" << id <<"уничтожен" << "\n";
   }
   static int getTotalCounters(){
       return totalCounters;      //статический метод для получения количества
   }
};

int Counter::totalCounters = 0;  //начальное значение
int main(){
    int N;
    cout << "сколько желаете счетчиков создать? " << "\n";
    cin >> N;
    Counter* counters = new Counter[N];     //создаю динамический массив с удалением соответственно
    cout << Counter::getTotalCounters() << "\n";  // до удалеия
    delete[] counters;
    cout << Counter::getTotalCounters() << "\n"; //здесь вывод количества после удаление массива
    
    
