#include <bits/stdc++.h>
using namespace std;
class Message{
private:
    string text;
    
public:
   Message(const string& message) : text(message){
       cout << "Создано сообщение: " << "["  << text << "]" << "\n";     //конструктор с парметром
   }
   ~Message(){
       cout << "Удалено сообщение: " << "[" << text << "]" << "\n";    //ИСПОЛЬЗОВАН ДЕСТРУКТОР
   }
   void print(){
       cout << "Выведено сообщение: " << text << "\n";    //ВЫВОД СООБЩЕНИЯ
   }

};



int main() {
    Message staticMessage("Первое сообщение ");
    staticMessage.print();      //СОЗДАНИЕ НА СТЕКЕ
    
    
    Message* dynamic = new Message("Второе сообщение");    //СОЗДАНИЕ ДИНАМИЧЕСКИ
    dynamic -> print();
    delete dynamic;     //УДАЛЕНИЕ  ОБЬКЕТА
    
    
    
    
    return 0;
	

}
